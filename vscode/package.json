{
	"name": "agentfiles-vscode",
	"displayName": "agentfiles",
	"description": "Browse, open, and install AI agent skills across 18 tools from one panel",
	"version": "0.1.0",
	"publisher": "railly",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Railly/agentfiles",
		"directory": "vscode"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": ["Other"],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "agentfiles",
					"title": "agentfiles",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"agentfiles": [
				{
					"type": "webview",
					"id": "agentfiles.library",
					"name": "Library"
				},
				{
					"type": "webview",
					"id": "agentfiles.sessions",
					"name": "Sessions"
				},
				{
					"type": "webview",
					"id": "agentfiles.dashboard",
					"name": "Dashboard"
				},
				{
					"type": "webview",
					"id": "agentfiles.marketplace",
					"name": "Marketplace"
				}
			]
		},
		"commands": [
			{
				"command": "agentfiles.refresh",
				"title": "agentfiles: Refresh",
				"icon": "$(refresh)"
			},
			{
				"command": "agentfiles.createSkill",
				"title": "agentfiles: Create skill",
				"icon": "$(add)"
			},
			{
				"command": "agentfiles.browseMarketplace",
				"title": "agentfiles: Search marketplace (quick pick)"
			},
			{
				"command": "agentfiles.updateAllSkills",
				"title": "agentfiles: Update all skills"
			},
			{
				"command": "agentfiles.removeSkillByName",
				"title": "agentfiles: Remove skill"
			},
			{
				"command": "agentfiles.openConversationTab",
				"title": "agentfiles: Open conversation in editor tab"
			},
			{
				"command": "agentfiles.openSkill",
				"title": "agentfiles: Open skill file"
			},
			{
				"command": "agentfiles.openDashboard",
				"title": "agentfiles: Focus dashboard"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "agentfiles.refresh",
					"when": "view == agentfiles.library",
					"group": "navigation@2"
				},
				{
					"command": "agentfiles.createSkill",
					"when": "view == agentfiles.library",
					"group": "navigation@1"
				}
			]
		}
	},
	"scripts": {
		"build": "node esbuild.config.mjs production",
		"dev": "node esbuild.config.mjs",
		"typecheck": "tsc --noEmit",
		"package": "vsce package --no-dependencies"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^20.14.0",
		"@types/vscode": "^1.90.0",
		"@vscode/vsce": "^3.2.1",
		"esbuild": "^0.24.0",
		"js-yaml": "^4.1.1",
		"typescript": "^5.6.0"
	}
}
